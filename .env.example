# =========================================================================
#  .env.example
#  Copy this file to `.env` and fill in your own values.
#  `.env` is in .gitignore, so it will NEVER be committed.
# =========================================================================


# -------------------------------------------------------------------------
# 1) GCP project - REQUIRED
# -------------------------------------------------------------------------
# Your Google Cloud project ID (string like "my-project-id-12345")
# or project number (12-digit integer). Either works.
# Get it from https://console.cloud.google.com  (top-left project selector).
# BigQuery scans are billed to this project.
GCP_PROJECT=


# -------------------------------------------------------------------------
# 2) Authentication - pick exactly ONE of the three options below
# -------------------------------------------------------------------------

# Option A (RECOMMENDED for local dev): Application Default Credentials.
# Don't set anything here. Install the gcloud CLI once, then run:
#   gcloud auth application-default login
#   gcloud auth application-default set-quota-project YOUR_PROJECT_ID


# Option B: short-lived access token (no install, expires in ~1 hour).
# Get it with:  gcloud auth print-access-token
# Then paste the value here. Leave blank to use option A or C.
BQ_TOKEN=


# Option C: service account JSON key (for servers / CI / shared workloads).
# In the Cloud Console: IAM & Admin -> Service Accounts -> Create Key (JSON).
# Give the SA the "BigQuery User" role. Paste the absolute path here.
# Example: GOOGLE_APPLICATION_CREDENTIALS=/home/you/keys/sa-bigquery.json
# Leave blank to use option A or B.
GOOGLE_APPLICATION_CREDENTIALS=
